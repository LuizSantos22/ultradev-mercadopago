<?xml version="1.0"?>
<config>
    <modules>
        <UltraDev_MercadoPago>
            <version>1.0.0</version>
        </UltraDev_MercadoPago>
    </modules>

    <global>
        <models>
            <ultradev_mercadopago>
                <class>UltraDev_MercadoPago_Model</class>
            </ultradev_mercadopago>
        </models>
        <blocks>
            <ultradev_mercadopago>
                <class>UltraDev_MercadoPago_Block</class>
            </ultradev_mercadopago>
        </blocks>
        <helpers>
            <ultradev_mercadopago>
                <class>UltraDev_MercadoPago_Helper</class>
            </ultradev_mercadopago>
        </helpers>
        <resources>
            <ultradev_mercadopago_setup>
                <setup>
                    <module>UltraDev_MercadoPago</module>
                </setup>
            </ultradev_mercadopago_setup>
        </resources>
    </global>

    <frontend>
        <routers>
            <ultradev_mercadopago>
                <use>standard</use>
                <args>
                    <module>UltraDev_MercadoPago</module>
                    <frontName>ultradev-mercadopago</frontName>
                </args>
            </ultradev_mercadopago>
        </routers>
        <layout>
            <updates>
                <ultradev_mercadopago>
                    <file>ultradev_mercadopago.xml</file>
                </ultradev_mercadopago>
            </updates>
        </layout>
        <translate>
            <modules>
                <UltraDev_MercadoPago>
                    <files>
                        <default>UltraDev_MercadoPago.csv</default>
                    </files>
                </UltraDev_MercadoPago>
            </translate>
        </translate>
    </frontend>

    <adminhtml>
        <translate>
            <modules>
                <UltraDev_MercadoPago>
                    <files>
                        <default>UltraDev_MercadoPago.csv</default>
                    </files>
                </UltraDev_MercadoPago>
            </translate>
        </translate>
    </adminhtml>

    <default>
        <payment>
            <ultradev_mercadopago_cc>
                <active>0</active>
                <model>ultradev_mercadopago/method_cc</model>
                <title>Cartão de Crédito (Mercado Pago)</title>
                <order_status>pending</order_status>
                <payment_action>authorize_capture</payment_action>
                <allowspecific>0</allowspecific>
                <sort_order>10</sort_order>
            </ultradev_mercadopago_cc>
            <ultradev_mercadopago_pix>
                <active>0</active>
                <model>ultradev_mercadopago/method_pix</model>
                <title>Pix (Mercado Pago)</title>
                <order_status>pending</order_status>
                <payment_action>authorize_capture</payment_action>
                <pix_expiration>PT30M</pix_expiration>
                <allowspecific>0</allowspecific>
                <sort_order>20</sort_order>
            </ultradev_mercadopago_pix>
            <ultradev_mercadopago_boleto>
                <active>0</active>
                <model>ultradev_mercadopago/method_boleto</model>
                <title>Boleto Bancário (Mercado Pago)</title>
                <order_status>pending</order_status>
                <payment_action>authorize_capture</payment_action>
                <boleto_expiration>P3D</boleto_expiration>
                <allowspecific>0</allowspecific>
                <sort_order>30</sort_order>
            </ultradev_mercadopago_boleto>
        </payment>
    </default>

    <crontab>
        <jobs>
            <ultradev_mercadopago_check_pending>
                <schedule><cron_expr>*/15 * * * *</cron_expr></schedule>
                <run><model>ultradev_mercadopago/observer::checkPendingOrders</model></run>
            </ultradev_mercadopago_check_pending>
        </jobs>
    </crontab>
</config>
