<?xml version="1.0"?>
<layout>
    <!-- Challenge 3DS — página isolada sem header/footer -->
    <ultradev_mercadopago_threeds_challenge>
        <update handle="page_empty"/>
        <reference name="root">
            <block type="core/template"
                   name="ultradev.mp.threeds.challenge"
                   template="ultradev/mercadopago/threeds/challenge.phtml"/>
        </reference>
    </ultradev_mercadopago_threeds_challenge>

    <!-- Página de sucesso — QR Pix ou link do Boleto -->
    <checkout_onepage_success>
        <reference name="content">
            <block type="core/template"
                   name="ultradev.mp.success"
                   template="ultradev/mercadopago/success/index.phtml"/>
        </reference>
    </checkout_onepage_success>

    <!-- Onepage padrão -->
    <checkout_onepage_index>
        <reference name="head">
            <action method="addCss">
                <stylesheet>ultradev/mercadopago/css/checkout.css</stylesheet>
            </action>
            <action method="addJs">
                <script>ultradev/mercadopago/js/mp-checkout.js</script>
            </action>
        </reference>
    </checkout_onepage_index>

    <!-- Moip One Step Checkout -->
    <onestepcheckout_index_index>
        <reference name="head">
            <action method="addCss">
                <stylesheet>ultradev/mercadopago/css/checkout.css</stylesheet>
            </action>
            <action method="addJs">
                <script>ultradev/mercadopago/js/mp-checkout.js</script>
            </action>
        </reference>
    </onestepcheckout_index_index>

    <!-- UltraDev Checkout (futuro) -->
    <ultradev_checkout_index_index>
        <reference name="head">
            <action method="addCss">
                <stylesheet>ultradev/mercadopago/css/checkout.css</stylesheet>
            </action>
            <action method="addJs">
                <script>ultradev/mercadopago/js/mp-checkout.js</script>
            </action>
        </reference>
    </ultradev_checkout_index_index>
</layout>
