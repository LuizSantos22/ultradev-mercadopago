            </div>

            <div class="mp-row">
                <div class="mp-field-group">
                    <label><?php echo $this->__('Validade'); ?></label>
                    <input type="text" id="mp_cardExpiration" maxlength="7" placeholder="MM/AAAA" autocomplete="cc-exp"/>
                </div>
                <div class="mp-field-group">
                    <label><?php echo $this->__('CVV'); ?></label>
                    <input type="text" id="mp_securityCode" maxlength="4" placeholder="123" autocomplete="cc-csc"/>
                </div>
            </div>

            <div class="mp-row">
                <div class="mp-field-group">
                    <label><?php echo $this->__('Tipo de Documento'); ?></label>
                    <select id="mp_docType">
                        <option value="CPF">CPF</option>
                        <option value="CNPJ">CNPJ</option>
                    </select>
                </div>
                <div class="mp-field-group">
                    <label><?php echo $this->__('CPF/CNPJ'); ?></label>
                    <input type="text" id="mp_docNumber" maxlength="18" placeholder="000.000.000-00"/>
                </div>
            </div>

            <div class="mp-field-group">
                <label><?php echo $this->__('Parcelas'); ?></label>
                <select id="mp_installments">
                    <option value="1"><?php echo $this->__('Selecione após digitar o cartão'); ?></option>
                </select>
            </div>

            <div id="mp-cc-msg"></div>

            <input type="hidden" id="mp_token"             name="payment[mp_token]"             value=""/>
            <input type="hidden" id="mp_payment_method_id" name="payment[mp_payment_method_id]" value=""/>
            <input type="hidden" id="mp_payment_type_id"   name="payment[mp_payment_type_id]"   value=""/>
            <input type="hidden" id="mp_installments_val"  name="payment[mp_installments]"      value="1"/>
            <input type="hidden" id="mp_doc_type_val"      name="payment[mp_doc_type]"          value=""/>
            <input type="hidden" id="mp_doc_number_val"    name="payment[mp_doc_number]"        value=""/>
        </div>

        <script>
        (function() {
            var publicKey  = '<?php echo $this->jsQuoteEscape($publicKey); ?>';
            var MP_SDK_URL = 'https://sdk.mercadopago.com/js/v2';
            var mp         = null;

            function showMsg(txt) {
                var el = document.getElementById('mp-cc-msg');
                if (!el) return;
                el.textContent = txt;
                el.style.display = txt ? 'block' : 'none';
            }

            function loadSDK(cb) {
                if (document.querySelector('script[src*="sdk.mercadopago"]')) {
                    waitForMP(cb); return;
                }
                var s = document.createElement('script');
                s.src = MP_SDK_URL;
                s.onload = function() { waitForMP(cb); };
                s.onerror = function() { showMsg('Erro ao carregar SDK do Mercado Pago.'); };
                document.head.appendChild(s);
            }

            function waitForMP(cb) {
                if (typeof MercadoPago !== 'undefined') { cb(); }
                else { setTimeout(function(){ waitForMP(cb); }, 200); }
            }

            function initMP() {
                if (mp) return;
                mp = new MercadoPago(publicKey, { locale: 'pt-BR' });
                bindCardNumber();
                bindExpiration();
            }

            function getAmount() {
                var el = document.querySelector('.grand-total .price');
                if (el) {
                    var val = el.textContent.replace(/[^\d,]/g, '').replace(',', '.');
                    var num = parseFloat(val);
                    if (!isNaN(num) && num > 0) return num;
                }
                return 0;
            }

            function bindCardNumber() {
                var input = document.getElementById('mp_cardNumber');
                if (!input) return;
                input.addEventListener('input', function() {
                    var v = this.value.replace(/\D/g, '').substring(0, 16);
                    this.value = v.replace(/(.{4})/g, '$1 ').trim();
                    if (v.length >= 6) { fetchInstallments(v); }
                });
            }

            function bindExpiration() {
                var input = document.getElementById('mp_cardExpiration');
                if (!input) return;
                input.addEventListener('input', function() {
                    var v = this.value.replace(/\D/g, '');
                    if (v.length >= 3) {
                        this.value = v.substring(0, 2) + '/' + v.substring(2, 6);
                    } else {
                        this.value = v;
                    }
                });
            }

            function fetchInstallments(cardNumber) {
                if (!mp) return;
                var bin    = cardNumber.substring(0, 6);
                var amount = parseFloat(getAmount());
                if (!(amount > 0)) return;

                mp.getInstallments({ bin: bin, amount: amount })
                  .then(function(result) {
                    console.log('[MP] installments result:', JSON.stringify(result));
                    if (!result || !result[0]) return;

                    var item = result[0];

                    // A API pode retornar erro como objeto dentro do array
                    if (item.code && item.message) {
                        console.warn('[MP] installments error:', item.message);
                        return;
                    }

                    var costs = item.payer_costs || item.payerCosts || [];
                    if (!costs.length) {
                        console.warn('[MP] payer_costs vazio:', JSON.stringify(item));
                        return;
                    }

                    var sel = document.getElementById('mp_installments');
                    document.getElementById('mp_payment_method_id').value = item.payment_method_id || '';
                    document.getElementById('mp_payment_type_id').value   = item.payment_type_id   || 'credit_card';

                    sel.innerHTML = '';
                    costs.forEach(function(p) {
                        var opt = document.createElement('option');
                        opt.value       = p.installments;
                        opt.textContent = p.recommended_message || p.installmentRate
                            ? (p.recommended_message || p.installments + 'x')
                            : p.installments + 'x';
                        sel.appendChild(opt);
                    });

                    document.getElementById('mp_installments_val').value = sel.value;
                    sel.onchange = function() {
                        document.getElementById('mp_installments_val').value = this.value;
                    };
                  })
                  .catch(function(e) { console.warn('[MP] getInstallments error:', e); });
            }

            window.mpGenerateToken = function(cb) {
                if (!mp) { cb(false, 'SDK não carregado'); return; }

                var num   = document.getElementById('mp_cardNumber').value.replace(/\s/g, '');
                var name  = document.getElementById('mp_cardholderName').value;
                var exp   = document.getElementById('mp_cardExpiration').value;
                var cvv   = document.getElementById('mp_securityCode').value;
                var doc   = document.getElementById('mp_docNumber').value;
                var dtype = document.getElementById('mp_docType').value;
                var inst  = document.getElementById('mp_installments').value;

                var expClean = exp.replace(/\D/g, '');
                var month    = expClean.substring(0, 2);
                var year     = expClean.substring(2);

                showMsg('');

                mp.createCardToken({
                    cardNumber:           num,
                    cardholderName:       name,
                    cardExpirationMonth:  month,
                    cardExpirationYear:   year,
                    securityCode:         cvv,
                    identificationType:   dtype,
                    identificationNumber: doc.replace(/\D/g, '')
                }).then(function(token) {
                    document.getElementById('mp_token').value            = token.id;
                    document.getElementById('mp_installments_val').value = inst;
                    document.getElementById('mp_doc_type_val').value     = dtype;
                    document.getElementById('mp_doc_number_val').value   = doc.replace(/\D/g, '');
                    cb(true);
                }).catch(function(err) {
                    console.error('[MP] createCardToken:', err);
                    var msg = (err && err[0] && err[0].message) ? err[0].message : 'Erro ao tokenizar cartão. Verifique os dados.';
                    showMsg(msg);
                    cb(false, msg);
                });
            };

            function interceptSubmit() {
                var btn = document.getElementById('checkout-onepage-buttom');
                if (!btn) { setTimeout(interceptSubmit, 500); return; }

                btn.addEventListener('click', function(e) {
                    var radio = document.getElementById('p_method_ultradev_mercadopago_cc');
                    if (!radio || !radio.checked) return;

                    e.preventDefault();
                    e.stopImmediatePropagation();

                    if (document.getElementById('mp_token').value) {
                        if (typeof payment !== 'undefined') { payment.save(); }
                        return;
                    }

                    window.mpGenerateToken(function(ok) {
                        if (ok) {
                            if (typeof payment !== 'undefined') { payment.save(); }
                        }
                    });
                }, true);
            }

            loadSDK(function() {
                initMP();
                interceptSubmit();
            });
        })();
        </script>
    </li>
</ul>
