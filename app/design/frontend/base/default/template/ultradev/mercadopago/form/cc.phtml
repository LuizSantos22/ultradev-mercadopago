</style>
<ul id="payment_form_<?php echo $code; ?>" style="display:none; list-style:none; padding:0; margin:0;">
    <li>
        <div id="mp-cc-form" class="mp-payment-form">

            <div class="mp-field-group">
                <label><?php echo $this->__('Número do Cartão'); ?></label>
                <input type="text" id="mp_cardNumber" maxlength="19" placeholder="0000 0000 0000 0000" autocomplete="cc-number"/>
            </div>

            <div class="mp-field-group">
                <label><?php echo $this->__('Nome no Cartão'); ?></label>
                <input type="text" id="mp_cardholderName" placeholder="Como está no cartão" autocomplete="cc-name"/>
            </div>

            <div class="mp-row">
                <div class="mp-field-group">
                    <label><?php echo $this->__('Validade'); ?></label>
                    <input type="text" id="mp_cardExpiration" maxlength="7" placeholder="MM/AAAA" autocomplete="cc-exp"/>
                </div>
                <div class="mp-field-group">
                    <label><?php echo $this->__('CVV'); ?></label>
                    <input type="text" id="mp_securityCode" maxlength="4" placeholder="123" autocomplete="cc-csc"/>
                </div>
            </div>

            <div class="mp-row">
                <div class="mp-field-group">
                    <label><?php echo $this->__('Tipo de Documento'); ?></label>
                    <select id="mp_docType" name="payment[mp_doc_type]">
                        <option value="CPF">CPF</option>
                        <option value="CNPJ">CNPJ</option>
                    </select>
                </div>
                <div class="mp-field-group">
                    <label><?php echo $this->__('CPF/CNPJ'); ?></label>
                    <input type="text" id="mp_docNumber" name="payment[mp_doc_number]" maxlength="18" placeholder="000.000.000-00"/>
                </div>
            </div>

            <div class="mp-field-group">
                <label><?php echo $this->__('Parcelas'); ?></label>
                <select id="mp_installments">
                    <option value="1"><?php echo $this->__('Aguardando número do cartão...'); ?></option>
                </select>
            </div>

            <div id="mp-cc-msg"></div>

            <input type="hidden" id="mp_token"             name="payment[mp_token]"             value=""/>
            <input type="hidden" id="mp_payment_method_id" name="payment[mp_payment_method_id]" value=""/>
            <input type="hidden" id="mp_payment_type_id"   name="payment[mp_payment_type_id]"   value=""/>
            <input type="hidden" id="mp_installments_val"  name="payment[mp_installments]"      value="1"/>
            <input type="hidden" id="mp_doc_type_val"      value=""/>
            <input type="hidden" id="mp_doc_number_val"    value=""/>
        </div>

        <script>
        (function() {
            var publicKey  = '<?php echo $this->jsQuoteEscape($publicKey); ?>';
            var MP_SDK_URL = 'https://sdk.mercadopago.com/js/v2';
            var mp         = null;

            function showMsg(txt) {
                var el = document.getElementById('mp-cc-msg');
                if (!el) return;
                el.textContent = txt;
                el.style.display = txt ? 'block' : 'none';
            }

            function loadSDK(cb) {
                if (window.__mpSDKLoaded) { waitForMP(cb); return; }
                if (document.querySelector('script[src*="sdk.mercadopago"]')) {
                    waitForMP(cb); return;
                }
                var s = document.createElement('script');
                s.src = MP_SDK_URL;
                s.onload = function() { window.__mpSDKLoaded = true; waitForMP(cb); };
                s.onerror = function() { showMsg('Erro ao carregar SDK do Mercado Pago.'); };
                document.head.appendChild(s);
            }

            function waitForMP(cb) {
                if (typeof MercadoPago !== 'undefined') { cb(); }
                else { setTimeout(function(){ waitForMP(cb); }, 200); }
            }

            function initMP() {
                if (mp) return;
                mp = new MercadoPago(publicKey, { locale: 'pt-BR' });
                bindCardNumber();
                bindExpiration();
            }

            function getAmount() {
                var el = document.querySelector('.grand-total .price');
                if (el) {
                    var val = el.textContent.replace(/[^\d,]/g, '').replace(',', '.');
                    var num = parseFloat(val);
                    if (!isNaN(num) && num > 0) return num;
                }
                return 0;
            }

            function detectBrand(num) {
                var n = num.replace(/\D/g, '');
                if (/^4/.test(n))                   return 'visa';
                if (/^5[1-5]/.test(n))              return 'master';
                if (/^3[47]/.test(n))               return 'amex';
                if (/^3(?:0[0-5]|[68])/.test(n))    return 'diners';
                if (/^(?:606282|3841)/.test(n))     return 'hipercard';
                if (/^(?:5067|4576|4011)/.test(n))  return 'elo';
                if (/^6(?:011|5)/.test(n))          return 'elo';
                return 'master';
            }

            function bindCardNumber() {
                var input = document.getElementById('mp_cardNumber');
                if (!input) return;
                input.addEventListener('input', function() {
                    var v = this.value.replace(/\D/g, '').substring(0, 16);
                    this.value = v.replace(/(.{4})/g, '$1 ').trim();
                    if (v.length >= 6) { fetchInstallments(v); }
                });
            }

            function bindExpiration() {
                var input = document.getElementById('mp_cardExpiration');
                if (!input) return;
                input.addEventListener('input', function() {
                    var v = this.value.replace(/\D/g, '');
                    if (v.length >= 3) {
                        this.value = v.substring(0, 2) + '/' + v.substring(2, 6);
                    } else {
                        this.value = v;
                    }
                });
            }

            function fetchInstallments(cardNumber) {
                if (!mp) return;
                var bin    = cardNumber.substring(0, 6);
                var amount = parseFloat(getAmount());
                if (!(amount > 0)) return;

                mp.getInstallments({ bin: bin, amount: amount })
                  .then(function(result) {
                    console.log('[MP] installments result:', JSON.stringify(result));
                    if (!result || !result[0]) { useFallback(cardNumber); return; }

                    var item = result[0];
                    if (item.code && item.message) {
                        console.warn('[MP] installments error:', item.message);
                        useFallback(cardNumber);
                        return;
                    }

                    var costs = item.payer_costs || item.payerCosts || [];
                    if (!costs.length) { useFallback(cardNumber); return; }

                    var maxInst = <?php echo (int) ($this->getConfigData('installments') ?: 12); ?>;

                    var sel = document.getElementById('mp_installments');
                    document.getElementById('mp_payment_method_id').value = item.payment_method_id || detectBrand(cardNumber);
                    document.getElementById('mp_payment_type_id').value   = item.payment_type_id   || 'credit_card';

                    sel.innerHTML = '';
                    costs.forEach(function(p) {
                        if (p.installments > maxInst) return;
                        var opt = document.createElement('option');
                        opt.value       = p.installments;
                        opt.textContent = p.recommended_message || (p.installments + 'x');
                        sel.appendChild(opt);
                    });

                    if (!sel.options.length) { useFallback(cardNumber); return; }

                    document.getElementById('mp_installments_val').value = sel.value;
                    sel.onchange = function() {
                        document.getElementById('mp_installments_val').value = this.value;
                    };
                  })
                  .catch(function(e) {
                    console.warn('[MP] getInstallments error:', e);
                    useFallback(cardNumber);
                  });
            }

            function useFallback(cardNumber) {
                var brand = detectBrand(cardNumber || document.getElementById('mp_cardNumber').value.replace(/\s/g, ''));
                document.getElementById('mp_payment_method_id').value = brand;
                document.getElementById('mp_payment_type_id').value   = 'credit_card';
                var sel = document.getElementById('mp_installments');
                var amt = getAmount();
                sel.innerHTML = '<option value="1">1x de R$' + amt.toFixed(2).replace('.', ',') + ' sem juros</option>';
                document.getElementById('mp_installments_val').value = '1';
            }

            window.mpGenerateToken = function(cb) {
                if (!mp) { cb(false, 'SDK não carregado'); return; }

                var num   = document.getElementById('mp_cardNumber').value.replace(/\s/g, '');
                var name  = document.getElementById('mp_cardholderName').value;
                var exp   = document.getElementById('mp_cardExpiration').value;
                var cvv   = document.getElementById('mp_securityCode').value;
                var doc   = document.getElementById('mp_docNumber').value.replace(/\D/g, '');
                var dtype = document.getElementById('mp_docType').value;
                var inst  = document.getElementById('mp_installments').value;

                if (!document.getElementById('mp_payment_method_id').value) {
                    useFallback(num);
                }

                var expClean = exp.replace(/\D/g, '');
                var month    = expClean.substring(0, 2);
                var year     = expClean.substring(2);

                showMsg('');

                mp.createCardToken({
                    cardNumber:           num,
                    cardholderName:       name,
                    cardExpirationMonth:  month,
                    cardExpirationYear:   year,
                    securityCode:         cvv,
                    identificationType:   dtype,
                    identificationNumber: doc
                }).then(function(token) {
                    document.getElementById('mp_token').value            = token.id;
                    document.getElementById('mp_installments_val').value = inst;
                    // Atualiza os campos com name para garantir envio correto
                    document.getElementById('mp_docNumber').value = doc;
                    document.getElementById('mp_docType').value   = dtype;
                    cb(true);
                }).catch(function(err) {
                    console.error('[MP] createCardToken:', err);
                    var msg = (err && err[0] && err[0].message) ? err[0].message : 'Erro ao tokenizar cartão. Verifique os dados.';
                    showMsg(msg);
                    cb(false, msg);
                });
            };

            function interceptSubmit() {
                document.addEventListener('click', function(e) {
                    var target = e.target;
                    while (target && target !== document) {
                        if (target.id === 'checkout-onepage-buttom') {
                            var radio = document.getElementById('p_method_ultradev_mercadopago_cc');
                            if (!radio || !radio.checked) return;

                            if (document.getElementById('mp_token').value) return;

                            e.preventDefault();
                            e.stopImmediatePropagation();
                            e.stopPropagation();

                            window.mpGenerateToken(function(ok) {
                                if (ok) {
                                    var btn = document.getElementById('checkout-onepage-buttom');
                                    var nativeClick = document.createEvent('MouseEvents');
                                    nativeClick.initMouseEvent('click', true, true, window,
                                        0, 0, 0, 0, 0, false, false, false, false, 0, null);
                                    btn.dispatchEvent(nativeClick);
                                }
                            });
                            return;
                        }
                        target = target.parentNode;
                    }
                }, true);
            }

            loadSDK(function() {
                initMP();
                interceptSubmit();
            });
        })();
        </script>
    </li>
</ul>
