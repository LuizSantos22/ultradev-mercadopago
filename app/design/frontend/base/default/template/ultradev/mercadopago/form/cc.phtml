<?php
/** @var UltraDev_MercadoPago_Block_Form_Cc $this */
$publicKey = $this->getPublicKey();
$code      = $this->getMethodCode();
?>
<style>
#cardPaymentBrick_container,
#cardPaymentBrick_container > div,
#cardPaymentBrick_container form,
#cardPaymentBrick_container .container-1-e9Cv {
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    box-sizing: border-box !important;
}
</style>
<ul id="payment_form_<?php echo $code; ?>" style="display:none; list-style:none; padding:0; margin:0;">
    <li>
        <div id="mp-cc-form" class="mp-payment-form" data-public-key="<?php echo $this->htmlEscape($publicKey); ?>">
            <div id="cardPaymentBrick_container"></div>
            <input type="hidden" id="mp_token"             name="payment[mp_token]"             value=""/>
            <input type="hidden" id="mp_payment_method_id" name="payment[mp_payment_method_id]" value=""/>
            <input type="hidden" id="mp_payment_type_id"   name="payment[mp_payment_type_id]"   value=""/>
            <input type="hidden" id="mp_installments"      name="payment[mp_installments]"      value="1"/>
            <input type="hidden" id="mp_doc_type"          name="payment[mp_doc_type]"          value=""/>
            <input type="hidden" id="mp_doc_number"        name="payment[mp_doc_number]"        value=""/>
        </div>
        <script>
        (function() {
            var publicKey = '<?php echo $this->jsQuoteEscape($publicKey); ?>';
            var MP_SDK_URL = 'https://sdk.mercadopago.com/js/v2';
            var MP_BRICK_INITIALIZED = false;

            function getAmount() {
                var el = document.querySelector('.grand-total .price');
                if (el) {
                    var val = el.textContent.replace(/[^\d,]/g, '').replace(',', '.');
                    var num = parseFloat(val);
                    if (!isNaN(num) && num > 0) return num;
                }
                var inp = document.querySelector('input.total_amount');
                if (inp && inp.value) return parseFloat(inp.value);
                return 0;
            }

            function initBrick() {
                if (MP_BRICK_INITIALIZED) return;
                if (typeof MercadoPago === 'undefined') return;
                MP_BRICK_INITIALIZED = true;

                var amount = getAmount();
                if (amount <= 0) {
                    console.warn('[MP Brick] Amount inválido:', amount);
                    return;
                }

                var mp     = new MercadoPago(publicKey, { locale: 'pt-BR' });
                var bricks = mp.bricks();

                bricks.create('cardPayment', 'cardPaymentBrick_container', {
                    initialization: { amount: amount },
                    callbacks: {
                        onReady: function() {
                            console.log('[MP Brick] Pronto, amount:', amount);
                        },
                        onSubmit: function(formData, additionalData) {
                            document.getElementById('mp_token').value             = formData.token;
                            document.getElementById('mp_payment_method_id').value = formData.payment_method_id;
                            document.getElementById('mp_payment_type_id').value   = (additionalData && additionalData.paymentTypeId) ? additionalData.paymentTypeId : 'credit_card';
                            document.getElementById('mp_installments').value      = formData.installments;
                            document.getElementById('mp_doc_type').value          = formData.payer.identification.type;
                            document.getElementById('mp_doc_number').value        = formData.payer.identification.number;
                            if (typeof payment !== 'undefined') { payment.save(); }
                            return Promise.resolve();
                        },
                        onError: function(err) {
                            console.error('[MP Brick] Erro:', err);
                        }
                    }
                });
            }

            function loadSDKAndInit() {
                if (document.querySelector('script[src*="sdk.mercadopago"]')) {
                    waitForMP(initBrick);
                    return;
                }
                var s = document.createElement('script');
                s.src = MP_SDK_URL;
                s.onload = function() { initBrick(); };
                s.onerror = function() { console.error('[MP] Falha ao carregar SDK'); };
                document.head.appendChild(s);
            }

            function waitForMP(cb) {
                if (typeof MercadoPago !== 'undefined') { cb(); }
                else { setTimeout(function(){ waitForMP(cb); }, 200); }
            }

            function isVisible(el) {
                return el.style.display !== 'none' && !el.classList.contains('no-display');
            }

            function watchVisibility() {
                var container = document.getElementById('payment_form_<?php echo $code; ?>');
                if (!container) { setTimeout(watchVisibility, 300); return; }

                var observer = new MutationObserver(function(mutations) {
                    mutations.forEach(function(m) {
                        if (m.type === 'attributes' && (m.attributeName === 'style' || m.attributeName === 'class')) {
                            if (isVisible(container) && !MP_BRICK_INITIALIZED) {
                                loadSDKAndInit();
                            }
                        }
                    });
                });

                observer.observe(container, { attributes: true, attributeFilter: ['style', 'class'] });

                // Verifica estado inicial
                if (isVisible(container)) {
                    loadSDKAndInit();
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', watchVisibility);
            } else {
                watchVisibility();
            }
        })();
        </script>
    </li>
</ul>
