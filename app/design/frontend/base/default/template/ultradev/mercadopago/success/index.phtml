<?php
$order     = Mage::getModel('sales/order')->loadByIncrementId(
    Mage::getSingleton('checkout/session')->getLastRealOrderId()
);
if (!$order->getId()) return;

$payment   = $order->getPayment();
$submethod = $payment->getAdditionalInformation('mp_submethod');
?>

<?php if ($submethod === 'pix'): ?>
<div class="ump-success-pix" style="margin:20px 0; padding:20px; border:1px solid #009ee3; border-radius:8px; text-align:center;">
    <h3>Pague com Pix!</h3>
    <p>Use o QR Code abaixo ou copie o código para pagar.</p>

    <?php $qrBase64 = $payment->getAdditionalInformation('pix_qr_base64'); ?>
    <?php if ($qrBase64): ?>
        <img src="data:image/png;base64,<?php echo $qrBase64 ?>"
             alt="QR Code Pix" style="max-width:220px; margin:12px auto; display:block;"/>
    <?php endif; ?>

    <?php $qrCode = $payment->getAdditionalInformation('pix_qr_code'); ?>
    <?php if ($qrCode): ?>
        <div style="margin-top:12px;">
            <strong>Pix Copia e Cola:</strong><br/>
            <textarea readonly onclick="this.select()"
                      style="width:100%; max-width:400px; margin-top:6px; padding:8px; font-size:12px; border-radius:4px; border:1px solid #ccc;"
            ><?php echo htmlspecialchars($qrCode) ?></textarea>
        </div>
        <button onclick="navigator.clipboard.writeText('<?php echo htmlspecialchars($qrCode) ?>').then(function(){ alert('Código copiado!'); })"
                style="margin-top:8px; padding:8px 16px; background:#009ee3; color:#fff; border:none; border-radius:4px; cursor:pointer;">
            Copiar Código Pix
        </button>
    <?php endif; ?>

    <p style="color:#666; font-size:13px; margin-top:12px;">O pagamento é confirmado em segundos após o pagamento.</p>
</div>
<?php endif; ?>

<?php if ($submethod === 'boleto'): ?>
<div class="ump-success-boleto" style="margin:20px 0; padding:20px; border:1px solid #6c4; border-radius:8px; text-align:center;">
    <h3>Seu Boleto foi gerado!</h3>

    <?php $boletoUrl = $payment->getAdditionalInformation('boleto_url'); ?>
    <?php if ($boletoUrl): ?>
        <a href="<?php echo $boletoUrl ?>" target="_blank" rel="noopener"
           style="display:inline-block; margin:12px 0; padding:10px 24px; background:#6c4; color:#fff; text-decoration:none; border-radius:4px; font-weight:bold;">
            Visualizar / Imprimir Boleto
        </a>
    <?php endif; ?>

    <?php $barcode = $payment->getAdditionalInformation('boleto_barcode'); ?>
    <?php if ($barcode): ?>
        <p><strong>Código de Barras:</strong></p>
        <input type="text" readonly value="<?php echo htmlspecialchars($barcode) ?>"
               onclick="this.select()"
               style="width:100%; max-width:500px; padding:8px; font-size:12px; border-radius:4px; border:1px solid #ccc;"/>
    <?php endif; ?>

    <p style="color:#666; font-size:13px; margin-top:12px;">
        Prazo de vencimento: <?php echo (int) Mage::getStoreConfig('payment/ultradev_mercadopago/boleto_due_days') ?: 3 ?> dias.
        A compensação pode levar até 3 dias úteis.
    </p>
</div>
<?php endif; ?>
