<?php
$session = UltraDev_MercadoPago_Model_ThreeDsSession::loadByQuoteId(
    (int) Mage::getSingleton('checkout/session')->getQuote()->getId()
);
$resourceUrl = $session->getExternalResourceUrl();
$creq        = $session->getCreq();
$paymentId   = (int) $session->getPaymentId();
$successUrl  = Mage::getUrl('checkout/onepage/success', ['_secure' => true]);
$statusUrl   = Mage::getUrl('ultradevmp/threeds/status', ['_secure' => true]);
?>
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"/>
    <title>Verificação 3D Secure</title>
    <style>
        body { margin:0; background:#f5f5f5; font-family:sans-serif; display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:100vh; }
        .ump-3ds-box { background:#fff; border-radius:8px; box-shadow:0 2px 16px rgba(0,0,0,.12); padding:24px; max-width:480px; width:100%; text-align:center; }
        .ump-3ds-box h2 { font-size:18px; margin-bottom:8px; }
        .ump-3ds-box p  { color:#666; font-size:14px; margin-bottom:16px; }
        #ump-3ds-iframe { width:100%; border:none; min-height:400px; border-radius:4px; }
        .ump-spinner { border:3px solid #eee; border-top:3px solid #009ee3; border-radius:50%; width:32px; height:32px; animation:spin 0.8s linear infinite; margin:16px auto; }
        @keyframes spin { to { transform:rotate(360deg); } }
    </style>
</head>
<body>
<div class="ump-3ds-box">
    <h2>Verificação de Segurança</h2>
    <p>Seu banco está verificando sua identidade. Isso pode levar alguns segundos.</p>
    <div class="ump-spinner" id="ump-spinner"></div>
    <iframe id="ump-3ds-iframe" style="display:none"
            src="<?php echo htmlspecialchars($resourceUrl) ?>"
            allow="payment">
    </iframe>
</div>

<form id="ump-3ds-form" name="tdsChallengeForm" method="POST"
      action="<?php echo htmlspecialchars($resourceUrl) ?>" target="ump-3ds-iframe">
    <input type="hidden" name="creq" value="<?php echo htmlspecialchars($creq) ?>"/>
</form>

<script src="https://sdk.mercadopago.com/js/v2"></script>
<script>
(function () {
    var paymentId  = <?php echo $paymentId ?>;
    var statusUrl  = '<?php echo $statusUrl ?>';
    var successUrl = '<?php echo $successUrl ?>';

    // Exibe iframe e submete o challenge
    window.addEventListener('load', function () {
        document.getElementById('ump-spinner').style.display = 'none';
        var iframe = document.getElementById('ump-3ds-iframe');
        iframe.style.display = '';
        document.getElementById('ump-3ds-form').submit();
    });

    // Polling de status a cada 3s
    UltraDevMP.startThreeDsPolling(paymentId, successUrl);

    // Escuta mensagem de conclusão do desafio via postMessage
    window.addEventListener('message', function (event) {
        if (event.data && event.data.status === 'COMPLETE') {
            UltraDevMP.startThreeDsPolling(paymentId, successUrl);
        }
    });
}());
</script>
</body>
</html>
